// This is an example .env file. Copy this to .env and fill in the values.

// The email and private key for the Google service account that will be used to access the Google Sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

// The email and password for the AD Courier account that will be used to add notes to candidates.
ADCOURIER_EMAIL=
ADCOURIER_PASSWORD=

// Gmail credentials for error notification emails (use an App Password, not your account password).
EMAIL_USER=
EMAIL_PASS=

// Run mode: "testing" skips business-hours restrictions (runs immediately, no 6pm cutoff, no weekend skip).
// "production" enforces the full 7am–6pm AEST scheduler behaviour.
RUN_MODE=testing

// How many days back to look for adverts during the 30-day fallback iteration.
LOOKBACK_DAYS=30
